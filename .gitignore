# Phase 4b runtime generated files (private)
backend/app/ml/runtime/extra_modules/**
backend/app/ml/runtime/configs/**
# whitelist README placeholders
!backend/app/ml/runtime/extra_modules/README.md
!backend/app/ml/runtime/configs/README.md

# Temporary files
tmp/
temp/
*.tmp
