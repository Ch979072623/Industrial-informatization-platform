{
  "type": "Conv_GN",
  "category": "atomic",
  "display_name": "Conv+GN+SiLU",
  "is_composite": true,
  "params_schema": [
    {"name": "c1", "type": "int", "default": 64, "min": 1, "description": "输入通道"},
    {"name": "c2", "type": "int", "default": 64, "min": 1, "description": "输出通道"},
    {"name": "k", "type": "int", "default": 1, "min": 1, "description": "卷积核大小"},
    {"name": "s", "type": "int", "default": 1, "min": 1, "description": "步长"},
    {"name": "p", "type": "int", "default": null, "description": "填充（null时module.py自动用k//2）"},
    {"name": "g", "type": "int", "default": 1, "min": 1, "description": "分组卷积组数"}
  ],
  "proxy_inputs": [
    {"sub_node_id": "conv", "port_index": 0, "name": "x"}
  ],
  "proxy_outputs": [
    {"sub_node_id": "silu", "port_index": 0, "name": "out"}
  ],
  "sub_nodes": [
    {"id": "conv", "type": "Conv2d", "params": {"in_channels": "${c1}", "out_channels": "${c2}", "kernel_size": "${k}", "stride": "${s}", "padding": "${p if p is not None else k // 2}", "groups": "${g}", "bias": false}, "position": {"x": 100, "y": 100}},
    {"id": "gn", "type": "GroupNorm", "params": {"num_groups": 16, "num_channels": "${c2}"}, "position": {"x": 100, "y": 200}},
    {"id": "silu", "type": "SiLU", "params": {}, "position": {"x": 100, "y": 300}}
  ],
  "sub_edges": [
    {"source": "conv", "source_port": 0, "target": "gn", "target_port": 0},
    {"source": "gn", "source_port": 0, "target": "silu", "target_port": 0}
  ]
}
