{
  "type": "SE",
  "category": "attention",
  "display_name": "通道注意力SE",
  "is_composite": true,
  "params_schema": [
    {"name": "in_channels", "type": "int", "default": 64, "min": 1, "description": "输入通道"},
    {"name": "reduction_ratio", "type": "int", "default": 16, "min": 1, "description": "压缩比"}
  ],
  "proxy_inputs": [
    {"sub_node_id": "identity_in", "port_index": 0, "name": "x"}
  ],
  "proxy_outputs": [
    {"sub_node_id": "mul", "port_index": 0, "name": "out"}
  ],
  "sub_nodes": [
    {"id": "identity_in", "type": "Identity", "params": {}, "position": {"x": 100, "y": 40}},
    {"id": "gap", "type": "AdaptiveAvgPool2d", "params": {"output_size": 1}, "position": {"x": 50, "y": 120}},
    {"id": "fc1", "type": "Conv2d", "params": {"in_channels": "${in_channels}", "out_channels": "${in_channels // reduction_ratio}", "kernel_size": 1, "bias": false}, "position": {"x": 50, "y": 200}},
    {"id": "relu", "type": "ReLU", "params": {}, "position": {"x": 50, "y": 280}},
    {"id": "fc2", "type": "Conv2d", "params": {"in_channels": "${in_channels // reduction_ratio}", "out_channels": "${in_channels}", "kernel_size": 1, "bias": false}, "position": {"x": 50, "y": 360}},
    {"id": "sigmoid", "type": "Sigmoid", "params": {}, "position": {"x": 50, "y": 440}},
    {"id": "mul", "type": "Mul", "params": {}, "position": {"x": 100, "y": 540}}
  ],
  "sub_edges": [
    {"source": "identity_in", "source_port": 0, "target": "gap", "target_port": 0},
    {"source": "identity_in", "source_port": 0, "target": "mul", "target_port": 0},
    {"source": "gap", "source_port": 0, "target": "fc1", "target_port": 0},
    {"source": "fc1", "source_port": 0, "target": "relu", "target_port": 0},
    {"source": "relu", "source_port": 0, "target": "fc2", "target_port": 0},
    {"source": "fc2", "source_port": 0, "target": "sigmoid", "target_port": 0},
    {"source": "sigmoid", "source_port": 0, "target": "mul", "target_port": 1}
  ]
}
