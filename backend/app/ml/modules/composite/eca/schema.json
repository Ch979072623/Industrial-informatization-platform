    {"id": "gap", "type": "AdaptiveAvgPool2d", "params": {"output_size": 1}, "position": {"x": 50, "y": 120}},
    {"id": "eca_conv", "type": "ECA_Conv1d", "params": {"in_channels": "${in_channels}", "gamma": "${gamma}", "b": "${b}"}, "position": {"x": 50, "y": 220}},
    {"id": "sigmoid", "type": "Sigmoid", "params": {}, "position": {"x": 50, "y": 320}},
    {"id": "mul", "type": "Mul", "params": {}, "position": {"x": 100, "y": 420}}
